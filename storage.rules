rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Como o Farrão é um evento fechado de conhecidos/família, 
      // basta estar logado no Auth do app para enviar fotos de recibos, local ou eventos.
      allow read, write: if request.auth != null;
    }
  }
}
